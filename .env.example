# Porta da API Express
PORT=4000

# Origem do frontend Next.js (CORS)
CLIENT_ORIGIN=http://localhost:3000

# Segredo usado para comparar senhas duplicadas sem salvar senha em texto puro
PASSWORD_PEPPER=troque_por_um_texto_secreto_grande

# Supabase/Postgres
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_ANON_KEY=sua_chave_anon_ou_publishable
# Produção: prefira SUPABASE_SERVICE_ROLE_KEY no backend e políticas RLS restritas.
